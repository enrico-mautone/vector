<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<title>Vector — Habit</title>
<style>
  body { font-family: system-ui, sans-serif; max-width: 900px; margin: 40px auto; padding: 0 16px; background:#0e0e10; color:#eee; }
  nav a { color:#3b82f6; margin-right:16px; text-decoration:none; }
  .tabs { margin: 16px 0; }
  .tabs a { display:inline-block; padding:6px 14px; margin-right:8px; border-radius:6px; text-decoration:none; color:#ccc; background:#1b1b1f; }
  .tabs a.active { background:#3b82f6; color:white; }
  .nav-arrows { margin-bottom: 16px; color:#ccc; }
  .nav-arrows a { color:#3b82f6; text-decoration:none; margin-right: 12px; }
  table.heatmap { border-collapse: collapse; }
  table.heatmap th { font-weight:normal; font-size:12px; color:#888; padding: 2px 6px; text-align:center; }
  table.heatmap td.habit-name { font-size:13px; padding-right:12px; white-space:nowrap; text-align:right; }
  table.heatmap td { padding:2px; }
  .cell { width:18px; height:18px; border-radius:3px; }
  .cell.l0 { background:#1b1b1f; }
  .cell.l1 { background:#0e4429; }
  .cell.l2 { background:#006d32; }
  .cell.l3 { background:#26a641; }
  .cell.l4 { background:#39d353; }
</style>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <a href="/log">Log</a>
    <a href="/habits">Habit calendario</a>
    <a href="/projects">Progetti</a>
    <a href="/settings">Impostazioni</a>
  </nav>

  <h1>Habit calendario</h1>

  <div class="tabs">
    <a href="/habits?view=year" class="<%= view === 'year' ? 'active' : '' %>">Annuale</a>
    <a href="/habits?view=month" class="<%= view === 'month' ? 'active' : '' %>">Mensile</a>
    <a href="/habits?view=week" class="<%= view === 'week' ? 'active' : '' %>">Settimanale</a>
  </div>

  <div class="nav-arrows">
    <% if (view === 'year') { %>
      <a href="/habits?view=year&year=<%= prevYear %>">&larr; <%= prevYear %></a>
      <strong><%= year %></strong>
      <a href="/habits?view=year&year=<%= nextYear %>"><%= nextYear %> &rarr;</a>
    <% } else if (view === 'month') { %>
      <a href="/habits?view=month&month=<%= prevMonth %>">&larr; precedente</a>
      <strong><%= month %>/<%= year %></strong>
      <a href="/habits?view=month&month=<%= nextMonth %>">successivo &rarr;</a>
    <% } else { %>
      <a href="/habits?view=week&week=<%= prevWeek %>">&larr; precedente</a>
      <a href="/habits?view=week&week=<%= nextWeek %>">successivo &rarr;</a>
    <% } %>
  </div>

  <table class="heatmap">
    <thead>
      <tr>
        <th></th>
        <% columns.forEach(function(c) { %>
          <th><%= c.label %></th>
        <% }); %>
      </tr>
    </thead>
    <tbody>
      <% rows.forEach(function(r) { %>
        <tr>
          <td class="habit-name"><%= r.habit.name %></td>
          <% r.cells.forEach(function(cell) { %>
            <td><div class="cell l<%= cell.level %>" title="<%= cell.title %>"></div></td>
          <% }); %>
        </tr>
      <% }); %>
    </tbody>
  </table>
</body>
</html>
