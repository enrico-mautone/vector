<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<title>Vector — Impostazioni</title>
<style>
  body { font-family: system-ui, sans-serif; max-width: 640px; margin: 40px auto; padding: 0 16px; background:#0e0e10; color:#eee; }
  nav a { color:#3b82f6; margin-right:16px; text-decoration:none; }
  fieldset { border:1px solid #333; border-radius:8px; margin-bottom:16px; padding:12px 16px; }
  legend { padding:0 6px; color:#aaa; }
  label.setting { display:flex; align-items:center; gap:10px; font-size:16px; }
  label.setting input { width:20px; height:20px; }
  .hint { color:#888; font-size:13px; margin:6px 0 0 30px; }
  button { margin-top:20px; padding:10px 16px; background:#3b82f6; color:white; border:none; border-radius:6px; cursor:pointer; }
  .saved { color:#4ade80; margin-bottom:16px; }
</style>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <a href="/log">Log</a>
    <a href="/habits">Habit calendario</a>
    <a href="/projects">Progetti</a>
    <a href="/settings">Impostazioni</a>
  </nav>

  <h1>Impostazioni</h1>
  <% if (typeof saved !== 'undefined' && saved) { %>
    <p class="saved">Salvato.</p>
  <% } %>

  <form method="POST" action="/settings">
    <fieldset>
      <legend>Ordine di priorità</legend>
      <label class="setting">
        <input type="checkbox" name="enforcePriorityOrder" <%= config.enforcePriorityOrder ? 'checked' : '' %>>
        Lo devi fare!!!!
      </label>
      <p class="hint">Se attivo, non puoi registrare uno step su un progetto a priorità minore
        finché non hai registrato almeno uno step oggi su ogni progetto a priorità maggiore.</p>
    </fieldset>
    <button type="submit">Salva</button>
  </form>
  <p><a href="/">&larr; torna alla home</a></p>
</body>
</html>
