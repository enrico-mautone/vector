<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<title>Vector — Progetti</title>
<style>
  body { font-family: system-ui, sans-serif; max-width: 640px; margin: 40px auto; padding: 0 16px; background:#0e0e10; color:#eee; }
  nav a { color:#3b82f6; margin-right:16px; text-decoration:none; }
  .project-row { display:flex; align-items:stretch; gap:12px; margin-bottom:12px; }
  .project-title-box { flex:1; min-height:64px; background:#1b1b1f; border-radius:8px; padding:0 16px; display:flex; align-items:center; }
  .project-title-box h3 { margin:0; font-size:20px; }
  .project-priority { width:72px; min-height:64px; background:#1b1b1f; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:40px; font-weight:800; color:#3b82f6; line-height:1; }
  a.button { display:inline-block; margin-top:20px; padding:10px 16px; background:#3b82f6; color:white; text-decoration:none; border-radius:6px; }
</style>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <a href="/log">Log</a>
    <a href="/steps">Step successivi</a>
    <a href="/habits">Habit calendario</a>
    <a href="/projects">Progetti</a>
    <a href="/settings">Impostazioni</a>
  </nav>

  <h1>Progetti</h1>

  <% projects.forEach(function(p) { %>
    <div class="project-row">
      <div class="project-priority"><%= p.priority %></div>
      <div class="project-title-box"><h3><%= p.name %></h3></div>
    </div>
  <% }); %>

  <a class="button" href="/steps">Step successivi &rarr;</a>
</body>
</html>
