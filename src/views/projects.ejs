<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<title>Vector — Progetti</title>
<style>
  body { font-family: system-ui, sans-serif; max-width: 640px; margin: 40px auto; padding: 0 16px; background:#0e0e10; color:#eee; }
  nav a { color:#3b82f6; margin-right:16px; text-decoration:none; }
  .project-item { margin-bottom:12px; border-radius:8px; background:#1b1b1f; overflow:hidden; }
  .project-row { display:flex; align-items:stretch; gap:12px; }
  .project-header { flex:1; min-height:64px; background:none; border:none; padding:0 16px; display:flex; align-items:center; justify-content:space-between; cursor:pointer; color:#eee; font:inherit; text-align:left; }
  .project-header h3 { margin:0; font-size:20px; }
  .project-priority { width:72px; min-height:64px; display:flex; align-items:center; justify-content:center; font-size:40px; font-weight:800; color:#3b82f6; line-height:1; flex-shrink:0; }
  .chevron { color:#888; font-size:14px; transition:transform 0.15s ease; margin-left:8px; }
  .project-item.open .chevron { transform:rotate(180deg); }
  .project-panel { display:none; padding:0 16px 16px; }
  .project-item.open .project-panel { display:block; }
  fieldset { border:1px solid #333; border-radius:8px; margin-bottom:12px; padding:12px 16px; }
  legend { padding:0 6px; color:#aaa; }
  input[type=text], textarea { width:100%; padding:6px; border-radius:4px; border:1px solid #333; background:#0e0e10; color:#eee; box-sizing:border-box; font-family:inherit; }
  textarea { min-height:80px; resize:vertical; }
  .add-row { display:flex; gap:8px; margin-top:8px; }
  .add-row input[type=text] { flex:1; }
  button { padding:8px 14px; background:#3b82f6; color:white; border:none; border-radius:6px; cursor:pointer; }
  ul { list-style:none; padding:0; margin:8px 0 16px; }
  li { display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid #222; cursor:grab; }
  li.done span.text { text-decoration:line-through; color:#666; }
  li form { margin:0; }
  li .text { flex:1; }
  li .handle { color:#555; }
  li.dragging { opacity:0.4; }
  li.drag-over { border-top:2px solid #3b82f6; }
  .delete-btn { background:none; border:none; color:#e5484d; font-size:16px; cursor:pointer; padding:0 4px; }
  .no-steps { color:#888; font-size:14px; padding:8px 0; }
</style>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <a href="/log">Log</a>
    <a href="/habits">Habit calendario</a>
    <a href="/projects">Progetti</a>
    <a href="/settings">Impostazioni</a>
  </nav>

  <h1>Progetti</h1>

  <% projects.forEach(function(p) { %>
    <div class="project-item <%= p.id === openProject ? 'open' : '' %>" data-project-item="<%= p.id %>">
      <div class="project-row">
        <div class="project-priority"><%= p.priority %></div>
        <button type="button" class="project-header" data-toggle="<%= p.id %>">
          <h3><%= p.name %></h3>
          <span class="chevron">&#9660;</span>
        </button>
      </div>
      <div class="project-panel">
        <ul class="steps-list" data-steps-list="<%= p.id %>">
          <% if (p.projectSteps.length === 0) { %>
            <li class="no-steps">Nessuno step ancora per questo progetto.</li>
          <% } %>
          <% p.projectSteps.forEach(function(s) { %>
            <li class="<%= s.done ? 'done' : '' %>" draggable="true" data-id="<%= s.id %>">
              <span class="handle">&#9776;</span>
              <form method="POST" action="/steps/<%= s.id %>/toggle">
                <input type="hidden" name="projectId" value="<%= p.id %>">
                <input type="checkbox" onchange="this.form.submit()" <%= s.done ? 'checked' : '' %>>
              </form>
              <span class="text"><%= s.text %></span>
              <form method="POST" action="/steps/<%= s.id %>/delete">
                <input type="hidden" name="projectId" value="<%= p.id %>">
                <button type="submit" class="delete-btn" title="Cancella">&times;</button>
              </form>
            </li>
          <% }); %>
        </ul>

        <fieldset>
          <legend>Aggiungi uno step</legend>
          <form method="POST" action="/steps/add" class="add-row">
            <input type="hidden" name="projectId" value="<%= p.id %>">
            <input type="text" name="text" placeholder="Prossimo step..." required>
            <button type="submit">+</button>
          </form>
        </fieldset>

        <fieldset>
          <legend>Caricamento massivo</legend>
          <form method="POST" action="/steps/bulk">
            <input type="hidden" name="projectId" value="<%= p.id %>">
            <textarea name="bulkText" placeholder="Incolla qui più step, uno per riga oppure separati da ';'"></textarea>
            <div style="margin-top:8px">
              <button type="submit">Carica step</button>
            </div>
          </form>
        </fieldset>
      </div>
    </div>
  <% }); %>

  <p><a href="/">&larr; torna alla home</a></p>

  <script>
    (function () {
      document.querySelectorAll('.project-header').forEach(function (header) {
        header.addEventListener('click', function () {
          var item = header.closest('.project-item');
          item.classList.toggle('open');
        });
      });

      document.querySelectorAll('.steps-list').forEach(function (list) {
        var projectId = list.getAttribute('data-steps-list');
        var dragging = null;

        list.addEventListener('dragstart', function (e) {
          var li = e.target.closest('li[draggable="true"]');
          if (!li) return;
          dragging = li;
          li.classList.add('dragging');
          e.dataTransfer.effectAllowed = 'move';
        });

        list.addEventListener('dragend', function (e) {
          var li = e.target.closest('li[draggable="true"]');
          if (li) li.classList.remove('dragging');
          list.querySelectorAll('li.drag-over').forEach(function (el) { el.classList.remove('drag-over'); });
          dragging = null;
        });

        list.addEventListener('dragover', function (e) {
          var li = e.target.closest('li[draggable="true"]');
          if (!li || li === dragging) return;
          e.preventDefault();
          list.querySelectorAll('li.drag-over').forEach(function (el) { el.classList.remove('drag-over'); });
          li.classList.add('drag-over');
        });

        list.addEventListener('drop', function (e) {
          var li = e.target.closest('li[draggable="true"]');
          if (!li || !dragging || li === dragging) return;
          e.preventDefault();
          li.classList.remove('drag-over');
          var items = Array.from(list.children);
          var fromIndex = items.indexOf(dragging);
          var toIndex = items.indexOf(li);
          if (fromIndex < toIndex) {
            li.after(dragging);
          } else {
            li.before(dragging);
          }
          saveOrder(list, projectId);
        });
      });

      function saveOrder(list, projectId) {
        var order = Array.from(list.querySelectorAll('li[data-id]')).map(function (li) {
          return li.getAttribute('data-id');
        });
        fetch('/steps/reorder', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ projectId: projectId, order: order }),
        });
      }
    })();
  </script>
</body>
</html>
