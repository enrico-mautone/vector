<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<title>Vector — Log</title>
<style>
  body { font-family: system-ui, sans-serif; max-width: 640px; margin: 40px auto; padding: 0 16px; background:#0e0e10; color:#eee; }
  nav a { color:#3b82f6; margin-right:16px; text-decoration:none; }
  fieldset { border:1px solid #333; border-radius:8px; margin-bottom:16px; padding:12px 16px; }
  legend { padding:0 6px; color:#aaa; }
  label { display:block; margin:8px 0 4px; }
  .project-block { margin-bottom:16px; }
  .project-block h3 { margin:0 0 8px; }
  .step-row { display:flex; align-items:center; gap:8px; padding:4px 0; }
  .step-row label { flex:1; margin:0; }
  .step-row input[type=number] { width:70px; padding:6px; border-radius:4px; border:1px solid #333; background:#1b1b1f; color:#eee; }
  .no-steps { color:#888; font-size:14px; }
  .no-steps a { color:#3b82f6; }
  button { margin-top:20px; padding:10px 16px; background:#3b82f6; color:white; border:none; border-radius:6px; cursor:pointer; }
  a { color:#3b82f6; }
</style>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <a href="/log">Log</a>
    <a href="/steps">Step successivi</a>
    <a href="/habits">Habit calendario</a>
  </nav>

  <h1>Log — <%= today %></h1>
  <form method="POST" action="/log">
    <fieldset>
      <legend>Progetti</legend>
      <% projects.forEach(function(p) { %>
        <div class="project-block">
          <h3><%= p.name %></h3>
          <% if (p.displaySteps.length === 0) { %>
            <p class="no-steps">Nessuno step aperto. <a href="/steps?project=<%= p.id %>">Aggiungine uno</a>.</p>
          <% } else { %>
            <% p.displaySteps.forEach(function(s) { %>
              <div class="step-row">
                <label>
                  <input type="checkbox" name="step_<%= s.id %>_done" <%= s.checkedToday ? 'checked' : '' %>>
                  <%= s.text %>
                </label>
                <input type="number" min="0" name="step_<%= s.id %>_minutes" placeholder="min" value="<%= s.minutesToday %>">
              </div>
            <% }); %>
          <% } %>
        </div>
      <% }); %>
    </fieldset>
    <fieldset>
      <legend>Habit</legend>
      <% config.habits.forEach(function(h) { %>
        <label>
          <input type="checkbox" name="habit_<%= h.id %>" <%= (todayEntry.habits && todayEntry.habits[h.id]) ? 'checked' : '' %>>
          <%= h.name %>
        </label>
      <% }); %>
    </fieldset>
    <button type="submit">Salva</button>
  </form>
  <p><a href="/">&larr; torna alla home</a></p>
</body>
</html>
