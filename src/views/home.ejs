<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<title>Vector</title>
<style>
  body { font-family: system-ui, sans-serif; max-width: 640px; margin: 40px auto; padding: 0 16px; background:#0e0e10; color:#eee; }
  nav a { color:#3b82f6; margin-right:16px; text-decoration:none; }
  h1 { margin-bottom: 4px; }
  .section-header { display:flex; align-items:center; justify-content:space-between; gap:12px; }
  .section-header h2 { margin:0; }
  .gate-badge { display:inline-block; padding:6px 12px; border-radius:6px; background:#3a1418; border:1px solid #e5484d; color:#ff9a9e; font-weight:700; font-size:13px; white-space:nowrap; }
  .today { color:#888; margin-top:0; }
  .action-row { display:flex; align-items:stretch; gap:12px; margin-bottom:8px; }
  .action { flex:1; padding:12px 16px; border-radius:8px; background:#1b1b1f; }
  .action.urgent { border-left:4px solid #e5484d; }
  .action.normal { border-left:4px solid #3b82f6; }
  .action.blocked { border-left:4px solid #333; opacity:0.5; }
  .action-priority { width:56px; min-height:100%; background:#1b1b1f; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:32px; font-weight:800; color:#3b82f6; line-height:1; }
  .action-row.blocked .action-priority { color:#555; }
  .blocked-hint { color:#666; font-style:italic; }
  .habit { display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid #222; }
  .habit label { display:flex; align-items:center; gap:8px; cursor:pointer; }
  .streak { color:#f5a623; }
  .empty { color:#4ade80; }
  .next-step { color:#ccc; display:flex; align-items:center; gap:8px; cursor:pointer; }
  .next-step .label { color:#888; }
  .no-step { color:#888; font-style:italic; }
  .quote { font-style:italic; color:#aaa; border-left:3px solid #3b82f6; padding:8px 12px; margin-bottom:20px; }
  .quote .author { display:block; margin-top:4px; font-style:normal; color:#666; font-size:0.9em; }
  input[type=checkbox] { width:18px; height:18px; cursor:pointer; }
  .toast { position:fixed; left:50%; bottom:24px; transform:translateX(-50%) translateY(20px); background:#166534; color:#eafff0; padding:12px 20px; border-radius:8px; font-weight:600; box-shadow:0 4px 16px rgba(0,0,0,0.4); opacity:0; transition:opacity 0.2s ease, transform 0.2s ease; pointer-events:none; }
  .toast.error { background:#7f1d1d; color:#ffe1e1; }
  .toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
</style>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <a href="/log">Log</a>
    <a href="/habits">Habit calendario</a>
    <a href="/projects">Progetti</a>
    <a href="/settings">Impostazioni</a>
  </nav>

  <h1>Vector</h1>
  <% if (quote) { %>
    <p class="quote">&laquo;<%= quote.text %>&raquo;<% if (quote.author) { %><span class="author">&mdash; <%= quote.author %></span><% } %></p>
  <% } %>
  <p class="today"><%= today %></p>

  <div class="section-header">
    <h2>Oggi</h2>
    <% if (config.enforcePriorityOrder) { %>
      <span class="gate-badge">Lo devi fare!!!!</span>
    <% } %>
  </div>
  <% if (actionsToday.length === 0) { %>
    <p class="empty">Tutto fatto per oggi.</p>
  <% } else { %>
    <% actionsToday.forEach(function(p) { %>
      <div class="action-row <%= p.workable ? '' : 'blocked' %>" data-project-row="<%= p.id %>">
        <div class="action-priority"><%= p.priority %></div>
        <div class="action <%= !p.workable ? 'blocked' : (p.urgent ? 'urgent' : 'normal') %>">
          <strong><%= p.name %></strong><br>
          <span class="step-slot" data-project="<%= p.id %>">
            <% if (p.nextStepText) { %>
              <label class="next-step">
                <input type="checkbox" class="step-checkbox" data-project="<%= p.id %>" data-step="<%= p.nextStepId %>">
                <span><span class="label">Prossimo:</span> <span class="step-text"><%= p.nextStepText %></span></span>
              </label>
            <% } else { %>
              <label class="next-step finish-project">
                <input type="checkbox" class="finish-checkbox" data-project="<%= p.id %>">
                <span class="no-step">Non ci sono più task, il progetto è terminato?</span>
              </label>
            <% } %>
          </span>
          <% if (p.workable && p.urgent) { %> — <strong>urgente</strong><% } %>
          <% if (!p.workable) { %>
            <span class="blocked-hint">Completa prima i progetti a priorità più alta.</span>
          <% } %>
        </div>
      </div>
    <% }); %>
  <% } %>

  <h2>Habit</h2>
  <% habitsStatus.forEach(function(h) { %>
    <div class="habit" data-habit-row="<%= h.id %>">
      <label>
        <input type="checkbox" class="habit-checkbox" data-habit="<%= h.id %>" <%= h.doneToday ? 'checked' : '' %>>
        <%= h.name %>
      </label>
      <span class="streak" data-streak="<%= h.id %>"><%= h.streak %>&#128293;</span>
    </div>
  <% }); %>

  <div id="toast" class="toast"></div>

  <script>
    (function () {
      var toastEl = document.getElementById('toast');
      var toastTimer = null;

      function showToast(message, isError) {
        toastEl.textContent = message;
        toastEl.className = 'toast show' + (isError ? ' error' : '');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(function () {
          toastEl.classList.remove('show');
        }, 2600);
      }

      document.body.addEventListener('change', function (e) {
        if (e.target.classList.contains('step-checkbox')) {
          onStepChecked(e.target);
        } else if (e.target.classList.contains('finish-checkbox')) {
          onFinishProjectChecked(e.target);
        } else if (e.target.classList.contains('habit-checkbox')) {
          onHabitToggled(e.target);
        }
      });

      function onStepChecked(checkbox) {
        if (!checkbox.checked) return;
        var projectId = checkbox.dataset.project;
        var stepId = checkbox.dataset.step;
        checkbox.disabled = true;
        fetch('/home/complete-step', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ projectId: projectId, stepId: stepId }),
        })
          .then(function (r) { return r.json().then(function (data) { return { status: r.status, data: data }; }); })
          .then(function (res) {
            if (!res.data.ok) {
              checkbox.checked = false;
              checkbox.disabled = false;
              showToast(res.data.error || 'Non registrato.', true);
              return;
            }
            var slot = document.querySelector('.step-slot[data-project="' + projectId + '"]');
            if (res.data.nextStepText) {
              slot.innerHTML =
                '<label class="next-step">' +
                '<input type="checkbox" class="step-checkbox" data-project="' + projectId + '" data-step="' + res.data.nextStepId + '">' +
                '<span><span class="label">Prossimo:</span> <span class="step-text"></span></span>' +
                '</label>';
              slot.querySelector('.step-text').textContent = res.data.nextStepText;
            } else {
              slot.innerHTML =
                '<label class="next-step finish-project">' +
                '<input type="checkbox" class="finish-checkbox" data-project="' + projectId + '">' +
                '<span class="no-step">Non ci sono più task, il progetto è terminato?</span>' +
                '</label>';
            }
            showToast('Ben fatto continua così!! +10pt', false);
          })
          .catch(function () {
            checkbox.checked = false;
            checkbox.disabled = false;
            showToast('Errore di rete, riprova.', true);
          });
      }

      function onFinishProjectChecked(checkbox) {
        if (!checkbox.checked) return;
        var projectId = checkbox.dataset.project;
        checkbox.disabled = true;
        fetch('/home/finish-project', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ projectId: projectId }),
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (!data.ok) {
              checkbox.checked = false;
              checkbox.disabled = false;
              showToast(data.error || 'Non registrato.', true);
              return;
            }
            var row = document.querySelector('.action-row[data-project-row="' + projectId + '"]');
            if (row) row.remove();
            showToast('Progetto archiviato.', false);
          })
          .catch(function () {
            checkbox.checked = false;
            checkbox.disabled = false;
            showToast('Errore di rete, riprova.', true);
          });
      }

      function onHabitToggled(checkbox) {
        var habitId = checkbox.dataset.habit;
        var wasChecked = checkbox.checked;
        checkbox.disabled = true;
        fetch('/home/toggle-habit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ habitId: habitId }),
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            checkbox.disabled = false;
            if (!data.ok) {
              checkbox.checked = !wasChecked;
              showToast(data.error || 'Non registrato.', true);
              return;
            }
            var streakEl = document.querySelector('[data-streak="' + habitId + '"]');
            if (streakEl) streakEl.textContent = data.streak + '\u{1F525}';
            if (data.done) showToast('Ben fatto continua così!! +10pt', false);
          })
          .catch(function () {
            checkbox.disabled = false;
            checkbox.checked = !wasChecked;
            showToast('Errore di rete, riprova.', true);
          });
      }
    })();
  </script>
</body>
</html>
